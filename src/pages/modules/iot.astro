---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import CtaBand from "../../components/CtaBand.astro";

const deviceCategories = [
  { category: "Personal safety", examples: "Guard panic buttons, resident emergency buttons" },
  { category: "Power & utilities", examples: "UPS monitors, generator sensors" },
  { category: "Environmental", examples: "Smoke detectors, flood sensors, temperature alarms" },
  { category: "Access control", examples: "Door contact sensors, gate loop detectors" },
  { category: "Perimeter", examples: "Fence vibration sensors, beam break detectors" },
  { category: "Vehicle", examples: "ANPR triggers, parking sensors" },
];
---

<Layout
  title="IoT Device Management — Sensors, Panic Buttons & More | SYAG"
  description="Connect panic buttons, environmental sensors, UPS monitors, and access points to SYAG. Device events feed your incident pipeline and trigger flow automation rules automatically."
>
  <PageHero
    label="IoT Devices"
    headline="Every sensor. <span style='color:#35E0FF'>One</span> security picture."
    subheadline="The panic button pressed in the lobby. The UPS that just lost power. The perimeter sensor that triggered at 3am. SYAG connects every IoT device in your facility to the same operational picture — so nothing is missed."
  />

  <section class="space-y-6">
    <h2 class="quartr-heading text-3xl font-semibold text-white">What IoT integration looks like in <span style="color:#ff8a3c">your facility</span></h2>
    <div class="grid gap-4 md:grid-cols-2">
      {[
        { title: "Panic button pressed", desc: "A guard presses their panic button. Within 3 seconds, an incident is created, the on-duty supervisor receives a push notification, and the two nearest guards are notified to respond. No radio call required." },
        { title: "UPS power failure", desc: "The UPS in the server room loses mains power. SYAG detects the device event, creates a maintenance incident, and notifies the facility manager. Response time: under 60 seconds." },
        { title: "Perimeter sensor triggered", desc: "A fence vibration sensor activates at the east boundary. SYAG's Flow rule checks the time (02:00) and creates a high-priority security incident. The camera covering that zone is automatically pulled up in the Operations Center." },
        { title: "Environmental sensor alert", desc: "A smoke sensor in the basement car park triggers. SYAG creates an emergency incident, notifies the guard team, and triggers the evacuation protocol flow." },
      ].map((uc) => (
        <div class="glass-card space-y-2">
          <h3 class="text-base font-semibold text-white">{uc.title}</h3>
          <p class="text-sm text-white/60">{uc.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="space-y-6">
    <h2 class="quartr-heading text-3xl font-semibold text-white">Connect your devices in <span style="color:#ff8a3c">minutes</span></h2>
    <p class="text-sm text-white/60 max-w-2xl">
      SYAG uses a system-managed device type catalog. Facility admins register device instances by
      selecting from a catalog of known types — no custom event schema configuration required.
    </p>
    <div class="overflow-hidden rounded-2xl border border-white/10">
      <table class="w-full text-left text-sm text-white/70">
        <thead class="bg-white/5 text-xs uppercase tracking-[0.2em] text-white/50">
          <tr>
            <th class="px-4 py-3">Category</th>
            <th class="px-4 py-3">Examples</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/10">
          {deviceCategories.map((d) => (
            <tr>
              <td class="px-4 py-3 text-white/80">{d.category}</td>
              <td class="px-4 py-3">{d.examples}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="space-y-6">
    <h2 class="quartr-heading text-3xl font-semibold text-white">Always know which devices are <span style="color:#4ade80">online</span></h2>
    <div class="glass-card space-y-3">
      <ul class="space-y-2 text-sm text-white/60">
        <li>Live device health dashboard: online / offline / battery low / last seen</li>
        <li>Automatic alert when a device goes offline unexpectedly</li>
        <li>Battery level monitoring for wireless devices</li>
        <li>Device event history: full log of all events from every device</li>
      </ul>
    </div>
  </section>

  <section class="glass-card space-y-3">
    <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/40">Connects with</p>
    <div class="flex flex-wrap gap-3">
      {[
        { label: "Flow Automation", href: "/modules/flow" },
        { label: "Incident Management", href: "/modules/incidents" },
        { label: "Camera & VMS", href: "/modules/cameras" },
      ].map((link) => (
        <a href={link.href} class="rounded-full border border-white/20 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-white/60 hover:border-white/50 hover:text-white/80">
          {link.label}
        </a>
      ))}
    </div>
  </section>

  <CtaBand
    headline="See how IoT devices and operations <span style='color:#35E0FF'>work together</span>."
    primaryLabel="Request a demo →"
    primaryHref="/demo"
  />
</Layout>
