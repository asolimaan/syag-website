---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import CtaBand from "../../components/CtaBand.astro";

const modules = [
  { num: "01", title: "Guard Management", desc: "Track, schedule, and manage your entire security team from one screen.", href: "/modules/guard-management" },
  { num: "02", title: "Patrol & Tours", desc: "Verify guard presence at every checkpoint. Every time.", href: "/modules/patrol" },
  { num: "03", title: "Camera & VMS", desc: "Your cameras don't just record. They act.", href: "/modules/cameras" },
  { num: "04", title: "IoT Devices", desc: "Connect every sensor, button, and monitor to your security operations.", href: "/modules/iot" },
  { num: "05", title: "Asset Management", desc: "Track everything you own, from purchase to retirement.", href: "/modules/assets" },
  { num: "06", title: "Visitor Management", desc: "Know exactly who enters your facility — and when they leave.", href: "/modules/visitors" },
  { num: "07", title: "Flow Automation", desc: "Build your security logic visually. No developer required.", href: "/modules/flow" },
  { num: "08", title: "Incident Management", desc: "From alert to resolution, nothing falls through the cracks.", href: "/modules/incidents" },
];
---

<Layout
  title="SYAG Modules — Guard, Camera, IoT, Assets, Visitors, Flow, Incidents"
  description="Explore all 8 SYAG modules. Guard management, cameras, IoT devices, asset tracking, visitor management, flow automation, incident management, and operations center — all included."
>
  <PageHero
    headline="Every module your facility needs. All in one platform."
    subheadline="SYAG's modules work independently or together. Start with the capability that matters most to your facility today — and activate more as your operations grow. All modules are included in every plan. No per-module fees."
  />

  <!-- MODULE GRID -->
  <section class="space-y-8">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {modules.map((m) => (
        <a href={m.href} class="glass-card space-y-3 block hover:border-white/30 transition-colors group">
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/30">{m.num}</p>
          <h3 class="text-base font-semibold text-white group-hover:text-white/90">{m.title}</h3>
          <p class="text-sm text-white/60">{m.desc}</p>
          <span class="text-xs font-semibold uppercase tracking-[0.2em] text-white/40 group-hover:text-white/70">Explore →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- HOW MODULES CONNECT -->
  <section class="space-y-6">
    <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl">Modules that talk to each other</h2>
    <p class="text-sm text-white/60 max-w-2xl">
      SYAG modules don't operate in silos. They share a common event and incident pipeline:
    </p>
    <div class="space-y-4">
      {[
        "A camera detects motion → Flow creates an incident → Guard Management dispatches the nearest guard → Incident is resolved and logged",
        "A visitor overstays their expected departure → Flow sends an alert → Supervisor receives notification → Incident is created",
        "An IoT panic button is pressed → Incident opens immediately → Ops Center operator sees it live → Guard is dispatched",
      ].map((flow) => (
        <div class="glass-card">
          <p class="text-sm text-white/70">{flow}</p>
        </div>
      ))}
    </div>
    <p class="text-sm text-white/60">
      The result: a complete operational picture, not a collection of disconnected tools.
    </p>
  </section>

  <CtaBand
    headline="See all modules in action."
    primaryLabel="Request a demo →"
    primaryHref="/demo"
    secondaryLabel="See pricing →"
    secondaryHref="/pricing"
  />
</Layout>
