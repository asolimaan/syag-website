---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import CtaBand from "../../components/CtaBand.astro";

const useCases = [
  {
    title: "Structured Visitor Access",
    desc: "Parents, contractors, delivery personnel, and event visitors all need structured access management. SYAG pre-registers authorised visitors and gives gate staff instant identity verification via QR code.",
  },
  {
    title: "Patrol Verification",
    desc: "Large campus perimeters require regular patrol coverage. SYAG's checkpoint scanning system verifies that every patrol point has been visited on every shift — with automated alerts when patrols fall behind schedule.",
  },
  {
    title: "Emergency Protocol Automation",
    desc: "Emergency situations — lockdowns, evacuations, medical incidents — require immediate and coordinated response. SYAG's Flow automation can trigger broadcast notifications to all guards and supervisors the moment an emergency is declared.",
  },
  {
    title: "Incident Documentation",
    desc: "Every incident on a school campus must be documented for safeguarding, insurance, and regulatory purposes. SYAG's incident management system ensures every incident is recorded with full evidence, timestamps, and responsible officer.",
  },
];
---

<Layout
  title="Campus Security Operations for Schools & Universities | SYAG"
  description="SYAG manages security across educational campuses with guard management, visitor access control, patrol verification, and emergency protocol automation."
>
  <PageHero
    label="Educational Campuses"
    headline="<span style='color:#4ade80'>Safe</span> campuses start with visible operations."
    subheadline="Educational campuses need security operations that are visible, accountable, and fast to respond. SYAG gives school and university security teams the tools to run a professional operation from a single platform."
  />

  <section class="space-y-6">
    <h2 class="quartr-heading text-3xl font-semibold text-white">Key use cases</h2>
    <div class="grid gap-6 md:grid-cols-2">
      {useCases.map((uc) => (
        <div class="glass-card space-y-3">
          <h3 class="text-base font-semibold text-white">{uc.title}</h3>
          <p class="text-sm text-white/60">{uc.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <CtaBand
    headline="See SYAG for your educational campus."
    primaryLabel="Request a demo →"
    primaryHref="/demo"
  />
</Layout>
