---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import CtaBand from "../../components/CtaBand.astro";

const solutions = [
  { title: "Gated Communities", desc: "HOA-style management with resident-facing visitor pre-registration, gate access logging, and community-wide incident awareness.", href: "/solutions/gated-communities" },
  { title: "Corporate Campuses", desc: "Multi-building guard coordination, structured visitor and contractor access, and cross-shift incident continuity across the full estate.", href: "/solutions/corporate-campuses" },
  { title: "Security Service Providers", desc: "Manage operations across your entire client portfolio with transparent execution, consistent reporting, and SLA-grade audit trails.", href: "/solutions/security-service-providers" },
  { title: "Critical Infrastructure", desc: "24/7 perimeter monitoring, IoT sensor integration, compliance-grade incident records, and strict access control across restricted zones.", href: "/solutions/critical-infrastructure" },
  { title: "Schools", desc: "Student safety, scheduled access for authorised visitors, patrol routes across large campuses, and emergency protocol automation.", href: "/solutions/education" },
  { title: "Hospitals", desc: "Patient safety, staff protection, contractor management, and 24/7 incident responsiveness across clinical zones.", href: "/solutions/healthcare" },
];
---

<Layout
  title="SYAG Solutions — Security Operations for Communities & Managed Facilities"
  description="SYAG is purpose-built for gated communities, mixed-use developments, industrial facilities, healthcare campuses, and educational institutions across the MEA region."
>
  <PageHero
    headline="Built for your kind of <span style='color:#ff8a3c'>facility</span>."
    subheadline="SYAG is not a generic security platform. It's designed around the specific operational realities of the facilities it serves. Find your facility type below."
  />

  <section class="space-y-6">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {solutions.map((s) => (
        <a href={s.href} class="glass-card space-y-3 block hover:border-white/30 transition-colors group">
          <h3 class="text-base font-semibold text-white group-hover:text-white/90">{s.title}</h3>
          <p class="text-sm text-white/60">{s.desc}</p>
          <span class="text-xs font-semibold uppercase tracking-[0.2em] text-white/40 group-hover:text-white/70">Learn more →</span>
        </a>
      ))}
    </div>
  </section>

  <CtaBand
    headline="Not sure which solution fits your facility?"
    body="Request a demo and we'll walk you through the right configuration for your specific setup."
    primaryLabel="Request a demo →"
    primaryHref="/demo"
  />
</Layout>
