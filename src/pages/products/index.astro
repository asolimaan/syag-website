---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import CtaBand from "../../components/CtaBand.astro";

const categories = [
  {
    label: "Guard Operations",
    desc: "Manage your security workforce — from daily shifts to every logged action.",
    products: [
      { title: "Guard Management", desc: "Schedule shifts, track GPS locations, manage attendance, and oversee your entire security team from one screen.", href: "/products/guard-management" },
      { title: "Guard Log Book", desc: "Every shift, checkpoint, and guard action — logged automatically, timestamped, and tamper-proof. Always audit-ready.", href: "/products/guard-management" },
      { title: "Team Communication", desc: "Coordinate guards and supervisors without leaving the platform. No more WhatsApp threads for security-critical messages.", href: "/products/guard-management" },
    ],
  },
  {
    label: "Monitoring & Devices",
    desc: "Connect your cameras and sensors to a live operational picture that acts — not just watches.",
    products: [
      { title: "Camera & VMS", desc: "Your cameras don't just record — they trigger alerts, create incidents, and feed your operations center in real time.", href: "/products/cameras" },
      { title: "IoT Devices", desc: "Panic buttons, motion detectors, UPS monitors, and environmental sensors — all connected to your incident pipeline.", href: "/products/iot" },
      { title: "Operations Center", desc: "A live dashboard showing every guard, active incident, camera event, and visitor across your facility — right now.", href: "/products/incidents" },
    ],
  },
  {
    label: "Access & Assets",
    desc: "Know who is on your premises and what you own — tracked from arrival to departure.",
    products: [
      { title: "Visitor Management", desc: "Issue QR passes, track check-ins and check-outs, flag overstays, and blacklist unwanted visitors — all automated.", href: "/products/visitors" },
      { title: "Asset Management", desc: "Track every piece of security equipment from purchase to retirement. Know what's working, what's due for maintenance, and what's missing.", href: "/products/assets" },
    ],
  },
  {
    label: "Response & Automation",
    desc: "Detect, respond, and automate — so your team acts faster with less manual effort.",
    products: [
      { title: "Incident Management", desc: "From the first alert to final resolution, every incident is tracked, assigned, and closed — nothing falls through the cracks.", href: "/products/incidents" },
      { title: "Flow Automation", desc: "Build your security logic visually — no developer required. When X happens, automatically do Y. Set it once, it runs forever.", href: "/products/flow" },
    ],
  },
];
---

<Layout
  title="SYAG Products — Everything Your Facility Needs in One Platform"
  description="Explore SYAG's complete product suite. Guard management, incident response, visitor control, smart monitoring, compliance reporting, and workflow automation — all in one platform."
>
  <PageHero
    headline="One platform. <span style='color:#4ade80'>Complete</span> operational control."
    subheadline="SYAG replaces your scattered tools with ten integrated pillars — guard management, guard log book, team communication, cameras, IoT devices, operations center, visitor management, asset management, incident management, and flow automation. Every product works standalone. Every product works better together."
    cta={{ label: "Request a demo →", href: "/demo" }}
  />

  <!-- PRODUCT CATEGORIES -->
  <section class="space-y-16">
    {categories.map((cat) => (
      <div class="space-y-6">
        <div class="space-y-2">
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/40">{cat.label}</p>
          <p class="text-sm text-white/60">{cat.desc}</p>
        </div>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {cat.products.map((p) => (
            <a href={p.href} class="glass-card space-y-3 block hover:border-white/30 transition-colors group">
              <h3 class="text-base font-semibold text-white group-hover:text-white/90">{p.title}</h3>
              <p class="text-sm text-white/60">{p.desc}</p>
              <span class="text-xs font-semibold uppercase tracking-[0.2em] text-white/40 group-hover:text-white/70">Learn more →</span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>

  <!-- CLOSING -->
  <section class="glass-card space-y-6 text-center py-12">
    <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl">
      One platform. Full <span style="color:#35E0FF">visibility</span>. <span style="color:#4ade80">Faster</span> response.
    </h2>
    <p class="mx-auto max-w-lg text-sm text-white/60">
      Every product in SYAG connects to the same operational picture. Incidents link to guards. Guards link to patrols. Visitors link to gates. Sensors link to alerts. You don't manage ten tools — you manage one facility.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a href="/demo" class="rounded-full bg-white px-5 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-black">
        Request a demo →
      </a>
      <a href="/pricing" class="rounded-full border border-white/30 px-5 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-white/80 hover:border-white">
        See pricing →
      </a>
    </div>
  </section>
</Layout>
