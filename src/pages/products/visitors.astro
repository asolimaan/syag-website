---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import CtaBand from "../../components/CtaBand.astro";
---

<Layout
  title="Visitor Management — QR Passes, Check-In, Blacklist | SYAG"
  description="Pre-register visitors with QR passes via WhatsApp. Guards scan at the gate. Overstay alerts, blacklist management, and contractor access — all in one system."
>
  <PageHero
    label="Visitor Management"
    headline="Know exactly who enters your facility — and when they <span style='color:#ff8a3c'>leave</span>."
    subheadline="Every visitor, every contractor, every delivery — logged, verified, and traceable. SYAG Visitor Management replaces the paper visitor book with a digital system that works the way your facility already operates."
  />

  <section class="space-y-6">
    <h2 class="quartr-heading text-3xl font-semibold text-white">Visitors arrive <span style="color:#4ade80">ready</span>. No queues at the gate.</h2>
    <div class="glass-card space-y-4">
      <p class="text-sm text-white/60">
        Residents and staff can pre-register visitors from the web portal or mobile app. SYAG generates
        a unique QR pass and sends it directly to the visitor via WhatsApp or SMS.
      </p>
      <p class="text-sm text-white/80">At the gate:</p>
      <p class="text-sm text-white/60">
        The guard scans the QR code with the SYAG app. Visitor identity is confirmed instantly.
        Access is approved or denied in under 10 seconds. No radio calls. No paper forms.
      </p>
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/40">QR pass contains</p>
      <ul class="space-y-1 text-sm text-white/60">
        <li>Visitor name and ID reference</li>
        <li>Approved entry window (date and time range)</li>
        <li>Host name and unit number</li>
        <li>Vehicle registration (if applicable)</li>
        <li>Single-use or multi-use setting</li>
        <li>Auto-expiry after the approved window</li>
      </ul>
    </div>
  </section>

  <section class="space-y-6">
    <h2 class="quartr-heading text-3xl font-semibold text-white">A <span style="color:#35E0FF">complete record</span> of every visit</h2>
    <div class="glass-card space-y-3">
      <p class="text-sm text-white/60">Every visit generates a timestamped entry and exit record:</p>
      <ul class="space-y-2 text-sm text-white/60">
        <li>Time of arrival (when QR was scanned at entry)</li>
        <li>Time of departure (when QR was scanned at exit)</li>
        <li>Gate used</li>
        <li>Guard who processed the visit</li>
        <li>Any notes or flags added during the visit</li>
      </ul>
      <p class="text-sm text-white/60">Full visit history per resident, per unit, and per visitor — searchable and exportable.</p>
    </div>
  </section>

  <section class="space-y-6">
    <h2 class="quartr-heading text-3xl font-semibold text-white">Know when a visitor <span style="color:#ef4444">hasn't left</span></h2>
    <div class="glass-card space-y-3">
      <p class="text-sm text-white/60">
        If a visitor's approved window expires and they haven't checked out, SYAG flags the overstay automatically.
      </p>
      <ul class="space-y-2 text-sm text-white/60">
        <li>Configurable grace period per visit type (e.g. 30 minutes for deliveries, 2 hours for social visits)</li>
        <li>Supervisor receives push notification when overstay threshold is reached</li>
        <li>Overstay appears in the active incidents view</li>
        <li>Guard can be dispatched to investigate</li>
      </ul>
    </div>
  </section>

  <section class="space-y-6">
    <h2 class="quartr-heading text-3xl font-semibold text-white"><span style="color:#ef4444">Flagged</span> individuals. Instant alerts.</h2>
    <div class="glass-card space-y-3">
      <p class="text-sm text-white/60">
        Maintain a facility blacklist for individuals who are not permitted entry — banned contractors,
        former residents, or individuals flagged by authorities.
      </p>
      <ul class="space-y-2 text-sm text-white/60">
        <li>Add individuals to the blacklist with reason and supporting documentation</li>
        <li>When a pre-registration is submitted for a blacklisted individual, the approving admin is alerted before entry is granted</li>
        <li>If a blacklisted individual presents at the gate, the guard is alerted immediately on scan</li>
        <li>Blacklist entries can be set to expire (time-limited bans) or permanent</li>
      </ul>
    </div>
  </section>

  <section class="space-y-6">
    <h2 class="quartr-heading text-3xl font-semibold text-white">Contractor access <span style="color:#4ade80">without the paperwork</span></h2>
    <div class="glass-card space-y-3">
      <ul class="space-y-2 text-sm text-white/60">
        <li>Define the approved work period (dates and times)</li>
        <li>Specify approved access zones within the facility</li>
        <li>Generate QR passes for all contractor personnel on the job</li>
        <li>Passes auto-expire at the end of the approved period</li>
        <li>Contractor visit history maintained for compliance and insurance purposes</li>
      </ul>
    </div>
  </section>

  <CtaBand
    headline="See visitor management in your facility."
    primaryLabel="Request a demo →"
    primaryHref="/demo"
  />
</Layout>
