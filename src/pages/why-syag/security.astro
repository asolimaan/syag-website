---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import CtaBand from "../../components/CtaBand.astro";
---

<Layout
  title="SYAG Security & Compliance — Architecture, Encryption, MEA Compliance"
  description="SYAG uses Azure infrastructure, schema-per-tenant data isolation, end-to-end encryption, RBAC, and full audit trails. Compliance path available for Saudi NCA and UAE IA."
>
  <PageHero
    label="Security & Compliance"
    headline="Your facility's data. Protected at every layer."
    subheadline="When you run security operations on SYAG, you're trusting us with sensitive information — guard locations, incident records, visitor identities. We take that responsibility seriously."
  />

  <!-- DATA ISOLATION -->
  <section class="space-y-4">
    <h2 class="quartr-heading text-3xl font-semibold text-white">Your data is yours. Always isolated.</h2>
    <div class="glass-card">
      <p class="text-sm text-white/60">
        Every facility on SYAG operates in its own isolated data environment. This is not a
        configuration option — it is how the platform is built. Your incident logs, visitor records,
        and guard data are stored in a completely separate database schema from every other customer.
        No data is ever shared or accessible across tenants.
      </p>
    </div>
  </section>

  <!-- INFRASTRUCTURE -->
  <section class="space-y-4">
    <h2 class="quartr-heading text-3xl font-semibold text-white">Infrastructure</h2>
    <div class="glass-card space-y-3">
      <p class="text-sm text-white/60">
        Microsoft Azure — enterprise-grade cloud hosting with regional data centres in the UAE and
        Saudi Arabia available for MEA customers requiring geographic data sovereignty.
      </p>
      <ul class="space-y-1 text-sm text-white/60">
        <li>99.9% uptime SLA</li>
        <li>Automated backups</li>
        <li>Disaster recovery</li>
        <li>DDoS protection via Azure Front Door</li>
      </ul>
    </div>
  </section>

  <!-- ENCRYPTION & ACCESS -->
  <section class="space-y-4">
    <h2 class="quartr-heading text-3xl font-semibold text-white">Encryption &amp; access control</h2>
    <div class="grid gap-6 md:grid-cols-2">
      <div class="glass-card space-y-3">
        <h3 class="text-base font-semibold text-white">Encryption</h3>
        <ul class="space-y-2 text-sm text-white/60">
          <li>TLS 1.3 for all data in transit</li>
          <li>AES-256 encryption at rest</li>
          <li>Passwords hashed with bcrypt</li>
        </ul>
      </div>
      <div class="glass-card space-y-3">
        <h3 class="text-base font-semibold text-white">Access control</h3>
        <ul class="space-y-2 text-sm text-white/60">
          <li>OAuth 2.0 / OpenID Connect authentication</li>
          <li>Role-based access: Guard, Supervisor, Admin, Ops Center</li>
          <li>Every action logged with user identity, timestamp, and IP</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- COMPLIANCE -->
  <section class="space-y-4">
    <h2 class="quartr-heading text-3xl font-semibold text-white">Compliance</h2>
    <div class="grid gap-6 md:grid-cols-2">
      <div class="glass-card space-y-3">
        <h3 class="text-base font-semibold text-white">Saudi NCA</h3>
        <p class="text-sm text-white/60">
          Architecture supports alignment with the National Cybersecurity Authority Essential Controls.
          Azure Front Door Premium upgrade available for regulated Saudi customers.
        </p>
      </div>
      <div class="glass-card space-y-3">
        <h3 class="text-base font-semibold text-white">UAE IA</h3>
        <p class="text-sm text-white/60">
          Data residency in UAE North Azure region available for customers under UAE Information
          Assurance requirements.
        </p>
      </div>
    </div>
    <div class="glass-card space-y-2">
      <h3 class="text-base font-semibold text-white">Full audit trail</h3>
      <p class="text-sm text-white/60">
        Every action on the SYAG platform is logged with user identity, timestamp, and IP address.
        Complete chain of custody for every incident, visitor record, and configuration change.
      </p>
    </div>
  </section>

  <CtaBand
    headline="Have specific compliance requirements?"
    body="Talk to our team — we'll walk you through the architecture."
    primaryLabel="Contact us →"
    primaryHref="/contact"
  />
</Layout>
