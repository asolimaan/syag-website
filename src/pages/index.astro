---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="SYAG — Security Operations Platform for Gated Communities & Managed Facilities"
  description="One platform for guard management, cameras, IoT, assets, visitors, and flow automation. Built for gated communities and managed facilities across MEA. Cloud SaaS. Live in 30 days."
>
  <!-- HERO -->
  <section class="hero-section relative overflow-hidden">
    <video class="hero-video" autoplay muted loop playsinline aria-hidden="true">
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>
    <div class="hero-content">
      <div class="space-y-6">
        <p class="text-sm font-semibold uppercase tracking-[0.4em] text-white/50">Physical security operations</p>
        <h1 class="quartr-heading text-5xl font-semibold text-white md:text-6xl lg:text-7xl">
          One <span style="color:#ff8a3c">screen</span>. Every <span style="color:#35E0FF">security signal</span> in your facility.
        </h1>
        <p class="max-w-xl text-base leading-relaxed text-white/60">
          SYAG unifies guard management, cameras, IoT sensors, assets, visitors, and flow automation
          in a single cloud platform — purpose-built for gated communities and managed facilities
          across the MEA region.
        </p>
        <div class="flex flex-wrap items-center gap-3">
          <a href="/demo" class="rounded-full bg-white px-6 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-black">
            See it live →
          </a>
        </div>
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-white/50">
          No servers. No integrators. Live in 30 days.
        </p>
      </div>
    </div>
  </section>



  <!-- PROBLEM SECTION -->
  <section class="space-y-6">
    <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/50">The problem every security team faces</p>
    <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl">
      You manage one facility. You're running <span style="color:#ef4444">ten tools</span>.
    </h2>
    <div class="mt-4 space-y-2 text-sm text-white/60 max-w-2xl">
      <p>
        Most security teams today operate with a guard management app, a separate VMS for cameras,
        a spreadsheet for assets, a paper register for visitors, and WhatsApp for everything else.
        Nothing connects. When something happens, you're switching between screens hoping you catch
        it in time.
      </p>
      <p class="text-white/80 font-medium">There's a better way.</p>
    </div>
  </section>

  <!-- TEN PILLARS -->
  <section class="space-y-10">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/50 mb-3">Everything your facility needs</p>
      <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl"><span style="color:#35E0FF">Ten pillars</span>. One <span style="color:#ff8a3c">platform</span>.</h2>
    </div>
    <div class="grid gap-4 md:grid-cols-6">
      <div class="glass-card space-y-3 md:col-span-2">
        <h3 class="text-base font-semibold text-white">Guard Management</h3>
        <p class="text-sm text-white/60">Know where every guard is, every second.</p>
      </div>
      <div class="glass-card space-y-3 md:col-span-2">
        <h3 class="text-base font-semibold text-white">Camera &amp; VMS</h3>
        <p class="text-sm text-white/60">Your cameras don't just record — they act.</p>
      </div>
      <div class="glass-card space-y-3 md:col-span-2">
        <h3 class="text-base font-semibold text-white">IoT Devices</h3>
        <p class="text-sm text-white/60">Every sensor feeds one security picture.</p>
      </div>
      <div class="glass-card space-y-3 md:col-span-3">
        <h3 class="text-base font-semibold text-white">Asset Management</h3>
        <p class="text-sm text-white/60">Everything you own, tracked from day one.</p>
      </div>
      <div class="glass-card space-y-3 md:col-span-3">
        <h3 class="text-base font-semibold text-white">Visitor Management</h3>
        <p class="text-sm text-white/60">Know exactly who enters your facility.</p>
      </div>
      <div class="glass-card space-y-3 md:col-span-2">
        <h3 class="text-base font-semibold text-white">Incident Management</h3>
        <p class="text-sm text-white/60">Detect, respond, and resolve — in one flow.</p>
      </div>
      <div class="glass-card space-y-3 md:col-span-2">
        <h3 class="text-base font-semibold text-white">Flow Automation</h3>
        <p class="text-sm text-white/60">Set your security logic once. Let it run.</p>
      </div>
      <div class="glass-card space-y-3 md:col-span-2">
        <h3 class="text-base font-semibold text-white">Operations Center</h3>
        <p class="text-sm text-white/60">Every signal, every guard, every incident — live.</p>
      </div>
      <div class="glass-card space-y-3 md:col-span-3">
        <h3 class="text-base font-semibold text-white">Guard Log Book</h3>
        <p class="text-sm text-white/60">Every shift, checkpoint, and event — logged automatically.</p>
      </div>
      <div class="glass-card space-y-3 md:col-span-3">
        <h3 class="text-base font-semibold text-white">Team Communication</h3>
        <p class="text-sm text-white/60">Coordinate your team without leaving the platform.</p>
      </div>
    </div>
  </section>

  <!-- WHO IT'S FOR -->
  <section class="space-y-10">
    <div class="flex flex-wrap items-center justify-between gap-6">
      <div>
        <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl">Who it&apos;s for</h2>
        <p class="mt-3 max-w-2xl text-sm text-white/60">
          Built for teams that run physical security across multiple sites, shifts, and stakeholders.
        </p>
      </div>
      <a href="/solutions" class="learn-more-btn">
        Learn more
        <span class="learn-more-icon">›</span>
      </a>
    </div>

    <div class="insight-grid">
      <a href="/solutions/gated-communities" class="insight-card tall hover:border-white/30 transition-colors">
        <div class="insight-hero">
          <video class="insight-video" autoplay muted loop playsinline aria-hidden="true">
            <source src="/videos/gated-community.webm" type="video/webm" />
          </video>
        </div>
        <div class="insight-content">
          <h3>Gated Communities</h3>
          <p>
            Coordinate guards, gates, and visitors across entrances with a single operational view
            and verified response outcomes.
          </p>
        </div>
      </a>

      <a href="/solutions/corporate-campuses" class="insight-card hover:border-white/30 transition-colors">
        <div class="insight-hero compact">
          <video class="insight-video" autoplay muted loop playsinline aria-hidden="true">
            <source src="/videos/firm.webm" type="video/webm" />
          </video>
        </div>
        <div class="insight-content">
          <h3>Corporate Campuses</h3>
          <p>Make fast, coordinated decisions across teams, buildings, and shifts.</p>
        </div>
      </a>

      <a href="/solutions/security-service-providers" class="insight-card hover:border-white/30 transition-colors">
        <div class="insight-hero compact">
          <video class="insight-video" autoplay muted loop playsinline aria-hidden="true">
            <source src="/videos/security.webm" type="video/webm" />
          </video>
        </div>
        <div class="insight-content">
          <h3>Security Service Providers</h3>
          <p>Deliver transparent execution and consistent reporting across your accounts.</p>
        </div>
      </a>

      <a href="/solutions/critical-infrastructure" class="insight-card hover:border-white/30 transition-colors">
        <div class="insight-hero compact">
          <video class="insight-video" autoplay muted loop playsinline aria-hidden="true">
            <source src="/videos/factory.webm" type="video/webm" />
          </video>
        </div>
        <div class="insight-content">
          <h3>Critical Infrastructure</h3>
          <p>Maintain real-time control with audit-ready records and resilient operations.</p>
        </div>
      </a>

      <a href="/solutions/education" class="insight-card hover:border-white/30 transition-colors">
        <div class="insight-hero compact">
          <video class="insight-video" autoplay muted loop playsinline aria-hidden="true">
            <source src="/videos/school.webm" type="video/webm" />
          </video>
        </div>
        <div class="insight-content">
          <h3>Schools</h3>
          <p>Keep staff, students, and visitors aligned with clear workflows and rapid response.</p>
        </div>
      </a>

      <a href="/solutions/healthcare" class="insight-card tall hover:border-white/30 transition-colors">
        <div class="insight-hero">
          <video class="insight-video" autoplay muted loop playsinline aria-hidden="true">
            <source src="/videos/hospital.webm" type="video/webm" />
          </video>
        </div>
        <div class="insight-content">
          <h3>Hospitals</h3>
          <p>Coordinate teams across clinical zones with fast escalation, visitor control, and audit-ready records.</p>
        </div>
      </a>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="space-y-8">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/50 mb-3">How SYAG works</p>
      <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl"><span style="color:#2F7BFF">Connect</span>. <span style="color:#ff8a3c">Automate</span>. <span style="color:#35E0FF">See</span> everything.</h2>
    </div>
    <div class="grid gap-6 md:grid-cols-3">
      <div class="glass-card space-y-3">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/40">Step 1</p>
        <h3 class="text-lg font-semibold text-white">Connect your site</h3>
        <p class="text-sm text-white/60">
          Link your cameras, IoT devices, and guard mobile app to SYAG. No hardware changes,
          no on-site servers. Setup takes days, not months.
        </p>
      </div>
      <div class="glass-card space-y-3">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/40">Step 2</p>
        <h3 class="text-lg font-semibold text-white">Set your rules</h3>
        <p class="text-sm text-white/60">
          Use the visual Flow editor to define your security logic. When a camera detects motion
          at the south gate after midnight, create an incident and notify the nearest supervisor.
          No developer required.
        </p>
      </div>
      <div class="glass-card space-y-3">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/40">Step 3</p>
        <h3 class="text-lg font-semibold text-white">See everything in one screen</h3>
        <p class="text-sm text-white/60">
          Your Operations Center shows every guard, every active incident, every camera event,
          and every visitor — live, in one place.
        </p>
      </div>
    </div>
  </section>

  <!-- MODULE HIGHLIGHTS -->
  <section class="space-y-10">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/50 mb-3">Platform highlights</p>
      <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl">
        Built for the way security operations <span style="color:#4ade80">actually work</span>
      </h2>
    </div>
    <div class="grid gap-6 md:grid-cols-3">
      <div class="glass-card space-y-4">
        <h3 class="text-lg font-semibold text-white">Guard Management</h3>
        <p class="text-sm text-white/60">
          Track every guard in real time. Assign patrols, verify checkpoints, and receive incident
          reports — all from mobile, over 4G.
        </p>
        <a href="/products/guard-management" class="text-xs font-semibold uppercase tracking-[0.2em] text-white/60 hover:text-white">
          Explore Guard Management →
        </a>
      </div>
      <div class="glass-card space-y-4">
        <h3 class="text-lg font-semibold text-white">Flow Automation</h3>
        <p class="text-sm text-white/60">
          Build your security logic visually. Camera trigger → incident created → supervisor notified
          → guard dispatched. Without writing a line of code.
        </p>
        <a href="/products/flow" class="text-xs font-semibold uppercase tracking-[0.2em] text-white/60 hover:text-white">
          Explore Flow Automation →
        </a>
      </div>
      <div class="glass-card space-y-4">
        <h3 class="text-lg font-semibold text-white">Visitor Management</h3>
        <p class="text-sm text-white/60">
          Pre-register visitors with a QR pass sent by WhatsApp. Guards scan at the gate. Overstays
          trigger automatic alerts. Blacklisted individuals are flagged on arrival.
        </p>
        <a href="/products/visitors" class="text-xs font-semibold uppercase tracking-[0.2em] text-white/60 hover:text-white">
          Explore Visitor Management →
        </a>
      </div>
    </div>
    <div class="text-center">
      <a href="/products" class="text-xs font-semibold uppercase tracking-[0.2em] text-white/60 hover:text-white">
        See all 8 modules →
      </a>
    </div>
  </section>

  <!-- COMPETITIVE GAP -->
  <section class="space-y-8">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/50 mb-3">Why SYAG</p>
      <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl">
        Guard software tracks guards. Enterprise PSIM costs a <span style="color:#ef4444">fortune</span>. SYAG does <span style="color:#2F7BFF">both</span> — without the complexity.
      </h2>
    </div>
    <div class="overflow-hidden rounded-2xl border border-white/10">
      <table class="w-full text-left text-sm text-white/70">
        <thead class="bg-white/5 text-xs uppercase tracking-[0.2em] text-white/50">
          <tr>
            <th class="px-4 py-3"></th>
            <th class="px-4 py-3">Guard Software</th>
            <th class="px-4 py-3">Enterprise PSIM</th>
            <th class="px-4 py-3 text-white font-semibold">SYAG</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/10">
          <tr>
            <td class="px-4 py-3 text-white/50">Guard management &amp; patrol</td>
            <td class="px-4 py-3">✓</td>
            <td class="px-4 py-3">✗</td>
            <td class="px-4 py-3 text-white font-semibold">✓</td>
          </tr>
          <tr>
            <td class="px-4 py-3 text-white/50">Camera / VMS integration</td>
            <td class="px-4 py-3">✗</td>
            <td class="px-4 py-3">✓</td>
            <td class="px-4 py-3 text-white font-semibold">✓</td>
          </tr>
          <tr>
            <td class="px-4 py-3 text-white/50">IoT device management</td>
            <td class="px-4 py-3">✗</td>
            <td class="px-4 py-3">✓</td>
            <td class="px-4 py-3 text-white font-semibold">✓</td>
          </tr>
          <tr>
            <td class="px-4 py-3 text-white/50">Asset management</td>
            <td class="px-4 py-3">✗</td>
            <td class="px-4 py-3">Partial</td>
            <td class="px-4 py-3 text-white font-semibold">✓</td>
          </tr>
          <tr>
            <td class="px-4 py-3 text-white/50">Visitor management</td>
            <td class="px-4 py-3">✗</td>
            <td class="px-4 py-3">✗</td>
            <td class="px-4 py-3 text-white font-semibold">✓</td>
          </tr>
          <tr>
            <td class="px-4 py-3 text-white/50">Flow automation</td>
            <td class="px-4 py-3">✗</td>
            <td class="px-4 py-3">Complex</td>
            <td class="px-4 py-3 text-white font-semibold">✓</td>
          </tr>
          <tr>
            <td class="px-4 py-3 text-white/50">Cloud SaaS, no servers</td>
            <td class="px-4 py-3">Partial</td>
            <td class="px-4 py-3">✗</td>
            <td class="px-4 py-3 text-white font-semibold">✓</td>
          </tr>
          <tr>
            <td class="px-4 py-3 text-white/50">MEA-native pricing</td>
            <td class="px-4 py-3">✗</td>
            <td class="px-4 py-3">✗</td>
            <td class="px-4 py-3 text-white font-semibold">✓</td>
          </tr>
        </tbody>
      </table>
    </div>
    <a href="/why-syag" class="text-xs font-semibold uppercase tracking-[0.2em] text-white/60 hover:text-white">
      See the full comparison →
    </a>
  </section>

  <!-- TESTIMONIAL -->
  <section class="space-y-8 text-center">
    <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/50">Trusted by facility security teams across the MEA region</p>
    <p class="mx-auto max-w-2xl text-lg font-semibold text-white">
      "{"{Quote from facility manager — specific, outcome-based.}"}"
    </p>
    <p class="text-sm text-white/60">— {"{Name}"}, Security Director, {"{Facility Name}"}, {"{City}"}</p>
  </section>

  <!-- PRICING TEASER -->
  <section class="space-y-8">
    <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl"><span style="color:#35E0FF">Transparent</span> pricing. No <span style="color:#ff8a3c">surprises</span>.</h2>
    <div class="grid gap-6 md:grid-cols-3">
      <div class="glass-card space-y-4">
        <h3 class="text-lg font-semibold text-white">Starter</h3>
        <p class="text-sm text-white/60">From {"{price}"}/month · Up to {"{X}"} guards · {"{X}"} site</p>
        <a href="/demo" class="block rounded-full border border-white/30 px-4 py-2 text-center text-xs font-semibold uppercase tracking-[0.2em] text-white/70 hover:border-white">
          Request a demo
        </a>
      </div>
      <div class="glass-card space-y-4 border border-white/20">
        <div class="flex items-center gap-2">
          <h3 class="text-lg font-semibold text-white">Professional</h3>
          <span class="text-xs font-semibold uppercase tracking-[0.2em] text-white/50">Most popular</span>
        </div>
        <p class="text-sm text-white/60">From {"{price}"}/month · Up to {"{X}"} guards · {"{X}"} sites</p>
        <a href="/demo" class="block rounded-full bg-white px-4 py-2 text-center text-xs font-semibold uppercase tracking-[0.2em] text-black">
          Request a demo
        </a>
      </div>
      <div class="glass-card space-y-4">
        <h3 class="text-lg font-semibold text-white">Business</h3>
        <p class="text-sm text-white/60">From {"{price}"}/month · Unlimited guards · Multiple sites</p>
        <a href="/demo" class="block rounded-full border border-white/30 px-4 py-2 text-center text-xs font-semibold uppercase tracking-[0.2em] text-white/70 hover:border-white">
          Request a demo
        </a>
      </div>
    </div>
    <p class="text-sm text-white/60">All modules included in every plan.</p>
    <a href="/pricing" class="text-xs font-semibold uppercase tracking-[0.2em] text-white/60 hover:text-white">
      See full pricing →
    </a>
  </section>

  <!-- DEPLOY YOUR WAY -->
  <section class="space-y-6">
    <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl">Deploy <span style="color:#4ade80">your way</span>.</h2>
    <div class="grid gap-6 md:grid-cols-3">
      <div class="glass-card space-y-3">
        <h3 class="text-lg font-semibold text-white">Cloud</h3>
        <p class="text-sm text-white/60">Fast onboarding with enterprise-grade security. Azure-hosted, fully managed.</p>
      </div>
      <div class="glass-card space-y-3">
        <h3 class="text-lg font-semibold text-white">Private Cloud</h3>
        <p class="text-sm text-white/60">Dedicated environment for sensitive operations. Full data isolation.</p>
      </div>
      <div class="glass-card space-y-3">
        <h3 class="text-lg font-semibold text-white">Regional</h3>
        <p class="text-sm text-white/60">UAE North or KSA data residency for compliance requirements.</p>
      </div>
    </div>
  </section>

  <!-- SECURITY & COMPLIANCE -->
  <section class="space-y-8">
    <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl"><span style="color:#ff8a3c">Security</span> &amp; compliance</h2>
    <div class="grid gap-5 sm:grid-cols-2">

      <!-- Data Isolation -->
      <div class="glass-card flex gap-5 items-start">
        <div class="shrink-0 mt-0.5">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <div class="space-y-1.5">
          <h3 class="text-base font-semibold text-white">Data Isolation</h3>
          <p class="text-sm text-white/60">Your data is completely separated — no cross-tenant access, ever.</p>
        </div>
      </div>

      <!-- Encryption -->
      <div class="glass-card flex gap-5 items-start">
        <div class="shrink-0 mt-0.5">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            <line x1="12" y1="16" x2="12" y2="16.01"/>
            <circle cx="12" cy="16" r="1" fill="white" stroke="none"/>
          </svg>
        </div>
        <div class="space-y-1.5">
          <h3 class="text-base font-semibold text-white">Encryption</h3>
          <p class="text-sm text-white/60">All data is protected in transit and at rest using strong encryption.</p>
        </div>
      </div>

      <!-- Access Control & Audit -->
      <div class="glass-card flex gap-5 items-start">
        <div class="shrink-0 mt-0.5">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <polyline points="16 11 18 13 22 9"/>
          </svg>
        </div>
        <div class="space-y-1.5">
          <h3 class="text-base font-semibold text-white">Access Control &amp; Audit</h3>
          <p class="text-sm text-white/60">Only authorized users can access the system — with full activity tracking.</p>
        </div>
      </div>

      <!-- Compliance Ready -->
      <div class="glass-card flex gap-5 items-start">
        <div class="shrink-0 mt-0.5">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <polyline points="9 12 11 14 15 10"/>
          </svg>
        </div>
        <div class="space-y-1.5">
          <h3 class="text-base font-semibold text-white">Compliance Ready</h3>
          <p class="text-sm text-white/60">Built to meet Saudi NCA and UAE IA security requirements.</p>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA BAND -->
