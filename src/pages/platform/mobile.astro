---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import CtaBand from "../../components/CtaBand.astro";
---

<Layout
  title="SYAG Mobile Apps — Guard & Supervisor Apps for Android and iOS"
  description="SYAG's mobile apps give guards and supervisors full operational capability in the field. Works over 4G on entry-level Android devices. Available in Arabic and English."
>
  <PageHero
    label="Mobile Apps"
    headline="Your facility fits in your <span style='color:#ff8a3c'>pocket</span>."
    subheadline="Security operations don't happen at a desk. SYAG's mobile apps give guards and supervisors everything they need in the field — patrol tracking, incident reporting, visitor scanning, and live dispatch — all over a standard 4G connection."
  />

  <!-- GUARD APP -->
  <section class="space-y-6">
    <h2 class="quartr-heading text-3xl font-semibold text-white">The Guard App — Built for the <span style="color:#ff8a3c">field</span></h2>
    <div class="glass-card space-y-4">
      <p class="text-sm text-white/60">
        Guards in your facility download the SYAG Guard App and operate their entire shift from
        their phone. No paper forms. No radio check-ins that go unlogged.
      </p>
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/40">What guards do on the app</p>
      <ul class="space-y-2 text-sm text-white/60">
        <li>Clock in and out with GPS-verified location</li>
        <li>View their patrol route and assigned checkpoints</li>
        <li>Scan NFC tags or QR codes at checkpoints to verify presence</li>
        <li>File incident reports with photos, audio, and GPS coordinates</li>
        <li>Receive dispatch notifications from supervisors</li>
        <li>View their shift schedule and post orders</li>
        <li>Submit handover notes at shift end</li>
      </ul>
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/40">Technical specs</p>
      <ul class="space-y-2 text-sm text-white/60">
        <li>Available on Android (4.4+) and iOS (12+)</li>
        <li>Optimised for entry-level Android devices — no high-spec hardware required</li>
        <li>Works over 4G cellular — no Wi-Fi required</li>
        <li>Offline mode: checkpoint scans and incident drafts saved locally, sync when connected</li>
        <li>Available in Arabic (RTL) and English</li>
      </ul>
    </div>
  </section>

  <!-- SUPERVISOR APP -->
  <section class="space-y-6">
    <h2 class="quartr-heading text-3xl font-semibold text-white">The Supervisor App — Command from <span style="color:#35E0FF">anywhere</span></h2>
    <div class="glass-card space-y-4">
      <p class="text-sm text-white/60">
        Supervisors see a live picture of their site without being chained to a control room screen.
      </p>
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/40">What supervisors do on the app</p>
      <ul class="space-y-2 text-sm text-white/60">
        <li>View the live guard map — see every active guard's position in real time</li>
        <li>Monitor patrol compliance — see which checkpoints have been scanned and which are overdue</li>
        <li>Receive incident notifications and approve or escalate</li>
        <li>Dispatch guards to specific locations</li>
        <li>Communicate with guards via in-app messaging</li>
        <li>View the incident feed for their site</li>
        <li>Access visitor logs and approve contractor access</li>
      </ul>
    </div>
  </section>

  <!-- ADMIN DASHBOARD -->
  <section class="space-y-6">
    <h2 class="quartr-heading text-3xl font-semibold text-white">The Admin Dashboard — <span style="color:#4ade80">Full control</span> from the browser</h2>
    <div class="glass-card space-y-4">
      <p class="text-sm text-white/60">
        Facility administrators access SYAG via the web dashboard — no software installation required.
        Any modern browser on any device.
      </p>
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/40">Admin capabilities</p>
      <ul class="space-y-2 text-sm text-white/60">
        <li>Configure sites, zones, and patrol routes</li>
        <li>Manage users, roles, and access permissions</li>
        <li>Set up Flow automation rules</li>
        <li>View the full Operations Center — all guards, incidents, cameras, and IoT devices</li>
        <li>Pull reports — incident trends, guard performance, visitor history, asset status</li>
        <li>Manage the visitor blacklist and contractor access</li>
      </ul>
      <p class="text-sm text-white/60">
        System requirements: Modern browser (Chrome, Firefox, Safari, Edge). Internet connection. No installation required.
      </p>
    </div>
  </section>

  <CtaBand
    headline="Request a demo to see the apps <span style='color:#ff8a3c'>in action</span>."
    primaryLabel="Request a demo →"
    primaryHref="/demo"
  />
</Layout>
