---
import "../styles/global.css";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>old_home — The operating system for physical security operations</title>
  </head>
  <body class="quartr-body">
    <div class="quartr-surface">
      <header class="mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-7">
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-full border border-white/20 bg-white/10 text-sm font-semibold text-white">
            S
          </div>
          <span class="text-sm font-semibold tracking-[0.3em] text-white/80">old_home</span>
        </div>
        <nav class="hidden items-center gap-8 text-xs font-semibold uppercase tracking-[0.2em] text-white/60 md:flex">
          <a class="hover:text-white" href="#">Product</a>
          <a class="hover:text-white" href="#">Solutions</a>
          <a class="hover:text-white" href="#">Pricing</a>
          <a class="hover:text-white" href="#">Security</a>
        </nav>
        <button class="hidden rounded-full border border-white/30 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-white/90 transition hover:border-white md:inline-flex">
          Request a demo
        </button>
      </header>

      <main class="mx-auto flex w-full max-w-6xl flex-col gap-24 px-6 pb-24">
        <section class="hero-section relative overflow-hidden">
          <video class="hero-video" autoplay muted loop playsinline aria-hidden="true">
            <source src="/axon-homepage-video-loop_v5-d1-comp51-s2-f19.mp4" type="video/mp4" />
          </video>
          <div class="hero-content">
            <div class="space-y-6">
              <p class="text-xs font-semibold uppercase tracking-[0.4em] text-white/50">Physical security operations</p>
              <h1 class="quartr-heading text-4xl font-semibold text-white md:text-5xl">
                Run security operations with clarity, speed, and accountability.
              </h1>
              <p class="max-w-md text-sm leading-relaxed text-white/60">
                old_home is the operating system for physical security operations across compounds,
                campuses, and critical facilities. Coordinate in real time, execute with precision,
                and maintain trusted records end to end.
              </p>
              <div class="flex flex-wrap items-center gap-3">
                <button class="rounded-full bg-white px-5 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-black">
                  Request a demo
                </button>
                <button class="rounded-full border border-white/30 px-5 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-white/80">
                  See how it works
                </button>
              </div>
              <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/50">
                Built for modern security teams managing real-world operations.
              </p>
            </div>
          </div>
        </section>

        <section class="hero-device-row">
          <div class="relative hero-media-stack">
            <div class="hero-mountain"></div>
            <div class="hero-device laptop">
              <div class="device-bar"></div>
              <div class="device-screen">
                <div class="screen-sidebar"></div>
                <div class="screen-content">
                  <div class="screen-row"></div>
                  <div class="screen-row short"></div>
                  <div class="screen-card"></div>
                  <div class="screen-row"></div>
                </div>
              </div>
            </div>
            <p class="mt-4 text-xs uppercase tracking-[0.3em] text-white/40">Product dashboard mockup</p>
            <div class="hero-device phone">
              <div class="device-notch"></div>
              <div class="phone-screen">
                <div class="phone-pill"></div>
                <div class="phone-grid">
                  <span></span>
                  <span></span>
                  <span></span>
                  <span></span>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="space-y-6 text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/50">
            Trusted by teams securing enterprise campuses and critical facilities
          </p>
          <div class="mx-auto flex flex-wrap items-center justify-center gap-8 text-xs font-semibold uppercase tracking-[0.2em] text-white/50">
            <span>Major Property Groups</span>
            <span>Enterprise Campuses</span>
            <span>Security Providers</span>
            <span>Large Compounds</span>
            <span>Critical Infrastructure</span>
          </div>
        </section>

        <section class="space-y-6">
          <div>
            <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl">
              Security is not about watching screens. It&apos;s about executing decisions.
            </h2>
            <div class="mt-4 space-y-2 text-sm text-white/60">
              <p>Not surveillance. Not just reporting. It is real-time coordination.</p>
              <p>old_home aligns people, sites, and events into one operational rhythm.</p>
            </div>
          </div>
        </section>

        <section class="space-y-10">
          <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl">Core pillars</h2>
          <div class="grid gap-6 md:grid-cols-3">
            <div class="glass-card space-y-4">
              <h3 class="text-lg font-semibold text-white">Operational Clarity</h3>
              <p class="text-sm text-white/60">Every event, signal, and decision in one live view.</p>
              <ul class="space-y-2 text-sm text-white/60">
                <li>Real-time visibility across every site</li>
                <li>Unified event stream with zero noise</li>
                <li>Live operations center view</li>
                <li>No blind spots across shifts</li>
              </ul>
              <p class="text-xs uppercase tracking-[0.3em] text-white/50">See the whole operation.</p>
            </div>
            <div class="glass-card space-y-4">
              <h3 class="text-lg font-semibold text-white">Execution Discipline</h3>
              <p class="text-sm text-white/60">Plan, dispatch, and verify every action.</p>
              <ul class="space-y-2 text-sm text-white/60">
                <li>Guard task management</li>
                <li>Patrol tracking with proof</li>
                <li>Escalations and handoffs</li>
                <li>SLA monitoring by site and team</li>
              </ul>
              <p class="text-xs uppercase tracking-[0.3em] text-white/50">Operate with consistency.</p>
            </div>
            <div class="glass-card space-y-4">
              <h3 class="text-lg font-semibold text-white">Accountability &amp; Trust</h3>
              <p class="text-sm text-white/60">Immutable records that stand up to scrutiny.</p>
              <ul class="space-y-2 text-sm text-white/60">
                <li>Audit logs with full traceability</li>
                <li>Evidence history attached to events</li>
                <li>Role-based access by team and site</li>
                <li>Compliance-ready records and chain of custody</li>
              </ul>
              <p class="text-xs uppercase tracking-[0.3em] text-white/50">Prove every decision.</p>
            </div>
          </div>
        </section>

        <section class="space-y-8">
          <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl">How it works</h2>
          <div class="grid gap-6 md:grid-cols-2">
            <div class="glass-card space-y-3">
              <h3 class="text-lg font-semibold text-white">Connect your sites</h3>
              <p class="text-sm text-white/60">
                Bring facilities, teams, and systems into one secure environment in days, not months.
              </p>
              <p class="text-sm text-white/60">Outcome: unified visibility from day one.</p>
            </div>
            <div class="glass-card space-y-3">
              <h3 class="text-lg font-semibold text-white">Structure your operations</h3>
              <p class="text-sm text-white/60">
                Define roles, patrol routes, escalation paths, and response standards across every site.
              </p>
              <p class="text-sm text-white/60">Outcome: consistent execution across shifts.</p>
            </div>
            <div class="glass-card space-y-3">
              <h3 class="text-lg font-semibold text-white">Automate alerts &amp; workflows</h3>
              <p class="text-sm text-white/60">
                Trigger the right actions at the right time, with clear ownership and accountability.
              </p>
              <p class="text-sm text-white/60">Outcome: faster, cleaner decisions.</p>
            </div>
            <div class="glass-card space-y-3">
              <h3 class="text-lg font-semibold text-white">Operate in real time</h3>
              <p class="text-sm text-white/60">
                Coordinate incidents live, track progress, and close out with verified evidence.
              </p>
              <p class="text-sm text-white/60">Outcome: confident operations in every moment.</p>
            </div>
          </div>
        </section>

        <section class="space-y-10">
          <div class="flex flex-wrap items-center justify-between gap-6">
            <div>
              <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl">Who it&apos;s for</h2>
              <p class="mt-3 max-w-2xl text-sm text-white/60">
                Built for teams that run physical security across multiple sites, shifts, and stakeholders.
              </p>
            </div>
            <button class="learn-more-btn">
              Learn more
              <span class="learn-more-icon">›</span>
            </button>
          </div>

          <div class="insight-grid">
            <div class="insight-card tall">
              <div class="insight-hero">
                <video class="insight-video" autoplay muted loop playsinline aria-hidden="true">
                  <source src="/videos/gated-community.mp4" type="video/mp4" />
                </video>
              </div>
              <div class="insight-content">
                <h3>Gated Communities</h3>
                <p>
                  Coordinate guards, gates, and visitors across entrances with a single operational view
                  and verified response outcomes.
                </p>
              </div>
            </div>

            <div class="insight-card">
              <div class="insight-hero compact">
                <video class="insight-video" autoplay muted loop playsinline aria-hidden="true">
                  <source src="/videos/firm.mp4" type="video/mp4" />
                </video>
              </div>
              <div class="insight-content">
                <h3>Corporate Campuses</h3>
                <p>Make fast, coordinated decisions across teams, buildings, and shifts.</p>
              </div>
            </div>

            <div class="insight-card">
              <div class="insight-hero compact">
                <video class="insight-video" autoplay muted loop playsinline aria-hidden="true">
                  <source src="/videos/security.mp4" type="video/mp4" />
                </video>
              </div>
              <div class="insight-content">
                <h3>Security Service Providers</h3>
                <p>Deliver transparent execution and consistent reporting across your accounts.</p>
              </div>
            </div>

            <div class="insight-card">
              <div class="insight-hero compact">
                <video class="insight-video" autoplay muted loop playsinline aria-hidden="true">
                  <source src="/videos/factory.mp4" type="video/mp4" />
                </video>
              </div>
              <div class="insight-content">
                <h3>Critical Infrastructure</h3>
                <p>Maintain real-time control with audit-ready records and resilient operations.</p>
              </div>
            </div>

            <div class="insight-card">
              <div class="insight-hero compact">
                <video class="insight-video" autoplay muted loop playsinline aria-hidden="true">
                  <source src="/videos/school.mp4" type="video/mp4" />
                </video>
              </div>
              <div class="insight-content">
                <h3>Schools</h3>
                <p>Keep staff, students, and visitors aligned with clear workflows and rapid response.</p>
              </div>
            </div>

            <div class="insight-card tall">
              <div class="insight-hero">
                <video class="insight-video" autoplay muted loop playsinline aria-hidden="true">
                  <source src="/videos/hospital.mp4" type="video/mp4" />
                </video>
              </div>
              <div class="insight-content">
                <h3>Hospitals</h3>
                <p>Coordinate teams across clinical zones with fast escalation, visitor control, and audit-ready records.</p>
              </div>
            </div>
          </div>
        </section>

        <section class="space-y-10">
          <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl">Product experience highlights</h2>
          <div class="grid gap-6 md:grid-cols-3">
            <div class="insight-card">
              <div class="insight-hero compact"></div>
              <div class="insight-content">
                <h3>Operations Center Dashboard</h3>
                <p>One screen where leaders see incidents, live status, and response progress instantly.</p>
              </div>
            </div>
            <div class="insight-card">
              <div class="insight-hero compact"></div>
              <div class="insight-content">
                <h3>Guard Mobile App</h3>
                <p>Field teams receive clear tasks, capture evidence, and close actions on the spot.</p>
              </div>
            </div>
            <div class="insight-card">
              <div class="insight-hero compact"></div>
              <div class="insight-content">
                <h3>Smart Alerts &amp; Automation</h3>
                <p>Signals become guided workflows that keep teams aligned and accountable.</p>
              </div>
            </div>
            <div class="insight-card">
              <div class="insight-hero compact"></div>
              <div class="insight-content">
                <h3>Visitor &amp; Access Management</h3>
                <p>Guests and deliveries flow smoothly with verified entry and instant audit trails.</p>
              </div>
            </div>
            <div class="insight-card">
              <div class="insight-hero compact"></div>
              <div class="insight-content">
                <h3>IoT &amp; Sensor Integration</h3>
                <p>Environmental and perimeter data connect directly to live operations.</p>
              </div>
            </div>
            <div class="insight-card">
              <div class="insight-hero compact"></div>
              <div class="insight-content">
                <h3>Task &amp; Workforce Coordination</h3>
                <p>Shifts, routes, and handoffs stay synchronized across all sites.</p>
              </div>
            </div>
          </div>
        </section>

        <section class="space-y-8 text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/50">Social proof</p>
          <div class="mx-auto flex flex-wrap items-center justify-center gap-8 text-xs font-semibold uppercase tracking-[0.2em] text-white/50">
            <span>Property Management Leaders</span>
            <span>Enterprise Campuses</span>
            <span>Security Providers</span>
            <span>Large Compounds</span>
          </div>
          <p class="mx-auto max-w-2xl text-lg font-semibold text-white">
            "old_home transformed how we coordinate our security teams across 14 sites."
          </p>
          <p class="text-sm text-white/60">Director of Security Operations</p>
        </section>

        <section class="space-y-10">
          <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl">Pricing</h2>
          <div class="grid gap-6 md:grid-cols-3">
            <div class="glass-card space-y-4">
              <h3 class="text-lg font-semibold text-white">Starter</h3>
              <p class="text-sm text-white/60">For single-site teams getting operational control fast.</p>
              <ul class="space-y-2 text-sm text-white/60">
                <li>Core operations dashboard</li>
                <li>Guard task management</li>
                <li>Basic alerts &amp; reporting</li>
              </ul>
              <p class="text-sm text-white/60">Best for growing communities and small campuses.</p>
              <button class="rounded-full border border-white/30 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-white/70">
                Request a demo
              </button>
            </div>
            <div class="glass-card space-y-4 border border-white/20">
              <h3 class="text-lg font-semibold text-white">Professional</h3>
              <p class="text-sm text-white/60">For multi-site operations that need live coordination.</p>
              <ul class="space-y-2 text-sm text-white/60">
                <li>Multi-site operations center</li>
                <li>Escalations &amp; SLA tracking</li>
                <li>Automation workflows</li>
                <li>Evidence &amp; audit trails</li>
              </ul>
              <p class="text-sm text-white/60">Best for enterprise campuses and service providers.</p>
              <button class="rounded-full bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-black">
                Request a demo
              </button>
            </div>
            <div class="glass-card space-y-4">
              <h3 class="text-lg font-semibold text-white">Enterprise</h3>
              <p class="text-sm text-white/60">For high-risk facilities with strict compliance needs.</p>
              <ul class="space-y-2 text-sm text-white/60">
                <li>Dedicated environments</li>
                <li>Advanced access controls</li>
                <li>Custom integrations</li>
                <li>Enterprise support &amp; onboarding</li>
              </ul>
              <p class="text-sm text-white/60">Best for critical infrastructure and regulated sites.</p>
              <button class="rounded-full border border-white/30 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-white/70">
                Contact Sales
              </button>
            </div>
          </div>
          <div class="overflow-hidden rounded-2xl border border-white/10">
            <table class="w-full text-left text-sm text-white/70">
              <thead class="bg-white/5 text-xs uppercase tracking-[0.2em] text-white/50">
                <tr>
                  <th class="px-4 py-3">Capability</th>
                  <th class="px-4 py-3">Starter</th>
                  <th class="px-4 py-3">Professional</th>
                  <th class="px-4 py-3">Enterprise</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/10">
                <tr>
                  <td class="px-4 py-3">Operations center</td>
                  <td class="px-4 py-3">Core view</td>
                  <td class="px-4 py-3">Multi-site</td>
                  <td class="px-4 py-3">Dedicated</td>
                </tr>
                <tr>
                  <td class="px-4 py-3">Automation</td>
                  <td class="px-4 py-3">Basic</td>
                  <td class="px-4 py-3">Advanced</td>
                  <td class="px-4 py-3">Custom</td>
                </tr>
                <tr>
                  <td class="px-4 py-3">Audit &amp; evidence</td>
                  <td class="px-4 py-3">Standard</td>
                  <td class="px-4 py-3">Expanded</td>
                  <td class="px-4 py-3">Compliance-grade</td>
                </tr>
                <tr>
                  <td class="px-4 py-3">Support</td>
                  <td class="px-4 py-3">Business hours</td>
                  <td class="px-4 py-3">Priority</td>
                  <td class="px-4 py-3">White-glove</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="space-y-6">
          <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl">Deploy your way.</h2>
          <div class="grid gap-6 md:grid-cols-3">
            <div class="glass-card space-y-3">
              <h3 class="text-lg font-semibold text-white">Secure multi-tenant cloud</h3>
              <p class="text-sm text-white/60">Fast onboarding with enterprise-grade security controls.</p>
            </div>
            <div class="glass-card space-y-3">
              <h3 class="text-lg font-semibold text-white">Dedicated private cloud</h3>
              <p class="text-sm text-white/60">Isolation for sensitive operations without extra complexity.</p>
            </div>
            <div class="glass-card space-y-3">
              <h3 class="text-lg font-semibold text-white">Regional hosting</h3>
              <p class="text-sm text-white/60">Keep data close to your sites and regulatory requirements.</p>
            </div>
          </div>
          <p class="text-sm text-white/60">
            Flexible deployment options that fit your environment, without slowing your teams down.
          </p>
        </section>

        <section class="space-y-6">
          <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl">Security &amp; compliance</h2>
          <div class="grid gap-6 md:grid-cols-2">
            <div class="glass-card space-y-3">
              <p class="text-sm text-white/60">End-to-end encryption across all data in transit and at rest.</p>
              <p class="text-sm text-white/60">Role-based permissions that reflect real operational needs.</p>
              <p class="text-sm text-white/60">Immutable audit logs to protect chain-of-custody records.</p>
              <p class="text-sm text-white/60">Tenant data isolation for enterprise readiness.</p>
            </div>
            <div class="glass-card space-y-3">
              <p class="text-sm text-white/60">
                Built for regulated environments with controlled access and verified actions.
              </p>
              <p class="text-sm text-white/60">
                old_home keeps your compliance posture strong while staying operationally simple.
              </p>
            </div>
          </div>
        </section>

        <section class="space-y-6 text-center">
          <h2 class="quartr-heading text-3xl font-semibold text-white md:text-4xl">
            Run security operations with confidence.
          </h2>
          <p class="mx-auto max-w-2xl text-sm text-white/60">
            old_home gives your team clarity, control, and accountability — in one unified platform.
          </p>
          <button class="mx-auto rounded-full bg-white px-5 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-black">
            Request a demo
          </button>
        </section>
      </main>

      <footer class="mx-auto w-full max-w-6xl px-6 pb-16">
        <div class="grid gap-8 border-t border-white/10 pt-10 text-sm text-white/60 md:grid-cols-4">
          <div class="space-y-2">
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/50">Product</p>
            <a class="block hover:text-white" href="#">Overview</a>
            <a class="block hover:text-white" href="#">Operations Center</a>
            <a class="block hover:text-white" href="#">Mobile App</a>
          </div>
          <div class="space-y-2">
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/50">Solutions</p>
            <a class="block hover:text-white" href="#">Gated Communities</a>
            <a class="block hover:text-white" href="#">Corporate Campuses</a>
            <a class="block hover:text-white" href="#">Security Providers</a>
            <a class="block hover:text-white" href="#">Critical Infrastructure</a>
          </div>
          <div class="space-y-2">
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/50">Company</p>
            <a class="block hover:text-white" href="#">Pricing</a>
            <a class="block hover:text-white" href="#">Security</a>
            <a class="block hover:text-white" href="#">Contact</a>
          </div>
          <div class="space-y-2">
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-white/50">Legal</p>
            <a class="block hover:text-white" href="#">Privacy</a>
            <a class="block hover:text-white" href="#">Terms</a>
          </div>
        </div>
        <p class="mt-8 text-xs uppercase tracking-[0.3em] text-white/40">
          old_home — The operating system for physical security operations.
        </p>
      </footer>
    </div>
  </body>
</html>
